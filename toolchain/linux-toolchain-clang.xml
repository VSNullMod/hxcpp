<xml>

<!-- LINUX CLANG TOOLS -->

<set name="ABITRIPLE" value="x86_64-linux-gnu" if="HXCPP_M64" unless="HXCPP_ARM64" />
<set name="ABITRIPLE" value="aarch64-linux-gnu" if="HXCPP_ARM64" />
<set name="ABITRIPLE" value="arm-linux-gnueabihf" if="HXCPP_ARMV7" />
<set name="ABITRIPLE" value="i686-linux-gnu" unless="HXCPP_M64 || HXCPP_ARM64 || HXCPP_ARMV7" />

<error value="Please set one of the architectures, eg HXCPP_ARM64, HXCPP_M32, ..." unless="ABITRIPLE" />

<set name="EXEPREFIX" value="llvm" />

<set name="HXCPP_CPP20" value="1" />

<include name="toolchain/gcc-toolchain.xml"/>
<set name="noM32" value="1" if="HXCPP_NO_M32" />
<set name="noM32" value="1" if="HXCPP_M64" />
<set name="noM32" value="1" if="HXCPP_ARM64 || HXCPP_ARMV7" />
<set name="noM64" value="1" if="HXCPP_ARM64 || HXCPP_ARMV7" />
<unset name="HXCPP_M64" if="noM64" />

<compiler id="linux" exe="clang++" if="linux">
  <exe name="${CXX}" if="CXX" />
  <flag value="--target=${ABITRIPLE}" if="ABITRIPLE" />
  <flag value="-c"/>
  <flag value="-flto" if="HXCPP_OPTIMIZE_LINK" unless="debug"/>
  <flag value="-fvisibility=hidden"/>
  <cppflag value="-stdlib=libc++" />
  <cppflag value="-frtti"/>
  <cppflag value="-std=c++11" if="HXCPP_CPP11" />
  <cppflag value="-std=c++17" if="HXCPP_CPP17" />
  <cppflag value="-std=c++20" if="HXCPP_CPP20" />
  <flag value="-g" if="HXCPP_DEBUG_LINK"/>
  <flag value="-O2" unless="debug"/>
  <flag value="-fpic"/>
  <flag value="-fPIC"/>
  <flag value="-Wno-inconsistent-missing-override"/>
  <cppflag value="-Wno-invalid-offsetof" />
  <flag value="-DHX_LINUX"/>
  <flag value="-DHXCPP_CLANG"/>
  <flag value="-DHXCPP_MULTI_THREADED" if="HXCPP_MULTI_THREADED"/>
  <flag value="-DHXCPP_BIG_ENDIAN" if="HXCPP_BIG_ENDIAN"/>
  <include name="toolchain/common-defines.xml" />
  <flag value="-m32" unless="noM32"/>
  <flag value="-m64" if="HXCPP_M64" unless="noM64" />
  <flag value="-DHXCPP_M64" if="HXCPP_M64" unless="noM64" />
  <flag value="-I${HXCPP}/include"/>
  <objdir value="obj/linux${OBJEXT}/"/>
  <outflag value="-o"/>
  <ext value=".o"/>
</compiler>

<linker id="dll" exe="clang++" if="linux">
  <exe name="${CXX}" if="CXX" />
  <flag value="--target=${ABITRIPLE}" if="ABITRIPLE" />
  <flag value="-shared"/>
  <flag value="-fpic"/>
  <flag value="-fPIC"/>
  <flag value="-stdlib=libc++" />
  <flag value="-m32" unless="noM32"/>
  <flag value="-m64" if="HXCPP_M64" unless="noM64" />
  <flag value="-Xlinker"/>
  <flag value="--no-undefined" unless="HXCPP_ALLOW_UNDEFINED" />
  <flag value="-debug" if="HXCPP_DEBUG_LINK" />
  <lib name="-ldl"/>
  <ext value=".dso"/>
  <outflag value="-o "/>
</linker>

<linker id="exe" exe="clang++" if="linux">
  <exe name="${CXX}" if="CXX" />
  <flag value="--target=${ABITRIPLE}" if="ABITRIPLE" />
  <flag value="-debug" if="HXCPP_DEBUG_LINK" />
  <flag value="-rdynamic"/>
  <flag value="-stdlib=libc++" />
  <flag value="-m32" unless="noM32"/>
  <flag value="-m64" if="HXCPP_M64" unless="noM64" />
  <flag value="-Wl,-rpath=$ORIGIN" />
  <lib name="-ldl"/>
  <ext value=""/>
  <outflag value="-o "/>
</linker>

</xml>